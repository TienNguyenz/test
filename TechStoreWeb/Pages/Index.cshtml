@page
@model IndexModel
@{
    ViewData["Title"] = "TechStore Control Center";
}

@if (!string.IsNullOrWhiteSpace(Model.StatusMessage))
{
    <div class="alert alert-info">@Model.StatusMessage</div>
}

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<section class="hero-panel mb-4">
    <div>
        <p class="hero-eyebrow mb-2">Unified Data Platform</p>
        <h1 class="hero-title mb-2">TechStore Control Center</h1>
        <p class="hero-subtitle mb-0">
            Hệ thống cung cấp một lớp dữ liệu logic thống nhất cho truy vấn nghiệp vụ và báo cáo giữa SQL Server và MySQL.
        </p>
    </div>
    <div class="hero-badges">
        <span class="env-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
            Product Data
        </span>
        <span class="env-badge">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            Sales Data
        </span>
        <span class="env-badge @(Model.Snapshot.LinkedServerHealthy ? "ok" : "bad")">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
            Integration: @(Model.Snapshot.LinkedServerHealthy ? "Healthy" : "Failed")
        </span>
    </div>
</section>

<section class="row g-3 mb-4">
    <div class="col-md-3 col-6">
        <div class="metric-card">
            <div class="metric-label">HQ Products</div>
            <div class="metric-value">@Model.Snapshot.HqProductCount</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="metric-card">
            <div class="metric-label">Branch Products</div>
            <div class="metric-value">@Model.Snapshot.BranchProductCount</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="metric-card">
            <div class="metric-label">Branch Invoices</div>
            <div class="metric-value">@Model.Snapshot.BranchInvoiceCount</div>
        </div>
    </div>
    <div class="col-md-3 col-6">
        <div class="metric-card">
            <div class="metric-label">Queue (P / S / E)</div>
            <div class="metric-value" style="font-size:1.2rem">
                <span style="color:var(--warn)">@Model.Snapshot.QueuePendingCount</span>
                <span style="color:var(--on-surface-dim)">/</span>
                <span style="color:var(--ok)">@Model.Snapshot.QueueSuccessCount</span>
                <span style="color:var(--on-surface-dim)">/</span>
                <span style="color:var(--bad)">@Model.Snapshot.QueueErrorCount</span>
            </div>
        </div>
    </div>
</section>

<div class="row g-3">
    <div class="col-md-6 col-lg-4">
        <div class="glass-card card-lift quick-nav-card h-100">
            <h5>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary)" stroke-width="2" style="margin-right:8px;vertical-align:-3px"><path d="M20.59 13.41l-7.17 7.17a2 2 0 01-2.83 0L2 12V2h10l8.59 8.59a2 2 0 010 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
                Product CRUD
            </h5>
            <p>Add, edit, delete products in one unified catalog workflow.</p>
            <a class="btn btn-brand" asp-page="/Products/Index">Open Products</a>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="glass-card card-lift quick-nav-card h-100">
            <h5>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--tertiary)" stroke-width="2" style="margin-right:8px;vertical-align:-3px"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 014 10 15.3 15.3 0 01-4 10 15.3 15.3 0 01-4-10 15.3 15.3 0 014-10z"/></svg>
                Distributed Evidence
            </h5>
            <p>Show transparent JOIN output, linked status, and queue telemetry.</p>
            <a class="btn btn-brand" asp-page="/Distributed/Evidence">Open Evidence</a>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="glass-card card-lift quick-nav-card h-100">
            <h5>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--ok)" stroke-width="2" style="margin-right:8px;vertical-align:-3px"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
                Revenue Report
            </h5>
            <p>Run sales report from one logical interface with date filtering.</p>
            <a class="btn btn-brand" asp-page="/Reports/Revenue">Open Revenue</a>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="glass-card card-lift quick-nav-card h-100">
            <h5>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--secondary)" stroke-width="2" style="margin-right:8px;vertical-align:-3px"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0020.49 15"/></svg>
                Price Sync Demo
            </h5>
            <p>Update HQ price, process queue, and verify branch update live.</p>
            <a class="btn btn-brand" asp-page="/Products/UpdatePrice">Open Sync Demo</a>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="glass-card card-lift quick-nav-card h-100">
            <h5>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--warn)" stroke-width="2" style="margin-right:8px;vertical-align:-3px"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                Invoices
            </h5>
            <p>Read invoice data through the logical query layer.</p>
            <a class="btn btn-brand" asp-page="/Invoices/Index">Open Invoices</a>
        </div>
    </div>

    <div class="col-md-6 col-lg-4">
        <div class="glass-card card-lift quick-nav-card h-100">
            <h5>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-dim)" stroke-width="2" style="margin-right:8px;vertical-align:-3px"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/></svg>
                Data Contracts
            </h5>
            <p>Field constraints and type compatibility mapping between two DBMSs.</p>
            <a class="btn btn-brand" asp-page="/Distributed/DataContracts">Open Contracts</a>
        </div>
    </div>
</div>
