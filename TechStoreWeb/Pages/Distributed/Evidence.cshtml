@page
@model TechStoreWeb.Pages.Distributed.EvidenceModel
@{
    ViewData["Title"] = "Distributed Evidence";
}

<div class="page-head mb-4">
    <h2>Distributed Database Evidence</h2>
    <p>Direct proof that this demo integrates SQL Server HQ and MySQL Branch without full migration.</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-label">Linked Server</div>
            <div class="metric-value @(Model.Snapshot.LinkedServerHealthy ? "ok" : "bad")">@(Model.Snapshot.LinkedServerHealthy ? "Healthy" : "Failed")</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-label">HQ Products</div>
            <div class="metric-value">@Model.Snapshot.HqProductCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-label">Branch Products</div>
            <div class="metric-value">@Model.Snapshot.BranchProductCount</div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="metric-card">
            <div class="metric-label">Branch Invoices</div>
            <div class="metric-value">@Model.Snapshot.BranchInvoiceCount</div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="metric-card">
            <div class="metric-label">Queue Pending</div>
            <div class="metric-value">@Model.Snapshot.QueuePendingCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <div class="metric-label">Queue Success</div>
            <div class="metric-value ok">@Model.Snapshot.QueueSuccessCount</div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="metric-card">
            <div class="metric-label">Queue Error</div>
            <div class="metric-value bad">@Model.Snapshot.QueueErrorCount</div>
        </div>
    </div>
</div>

@if (!string.IsNullOrWhiteSpace(Model.Snapshot.LinkedServerError))
{
    <div class="alert alert-warning">Linked Server detail: @Model.Snapshot.LinkedServerError</div>
}

<div class="glass-card p-4 mb-4">
    <h4 class="mb-3">Transparent JOIN Query (Requirement #2)</h4>
    <pre class="sql-box mb-0">SELECT p.ProductID, p.ProductName, p.Price, h.Quantity, CAST(h.SaleDate AS DATETIME2(0)) AS SaleDate, h.Total
FROM TechStore_HQ.dbo.SanPham p
JOIN OPENQUERY(MYSQL,
'    SELECT ProductID, Quantity, SaleDate, Total
     FROM TechStore_Branch.HoaDon') h
    ON p.ProductID = CAST(h.ProductID AS INT);</pre>
</div>

<form method="get" class="row g-3 mb-3">
    <div class="col-md-3">
        <label asp-for="FromDate" class="form-label">From Date</label>
        <input asp-for="FromDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="ToDate" class="form-label">To Date</label>
        <input asp-for="ToDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-brand" type="submit">Filter JOIN Result</button>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>ProductID</th>
                <th>ProductName</th>
                <th class="text-end">HQPrice</th>
                <th class="text-end">Quantity</th>
                <th>SaleDate</th>
                <th class="text-end">BranchTotal</th>
                <th class="text-end">RevenueByHQPrice</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var row in Model.JoinRows)
        {
            <tr>
                <td>@row.ProductID</td>
                <td>@row.ProductName</td>
                <td class="text-end">@row.HQPrice.ToString("N0")</td>
                <td class="text-end">@row.Quantity</td>
                <td>@row.SaleDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                <td class="text-end">@row.BranchTotal.ToString("N0")</td>
                <td class="text-end">@row.RevenueByHQPrice.ToString("N0")</td>
            </tr>
        }
        </tbody>
    </table>
</div>
