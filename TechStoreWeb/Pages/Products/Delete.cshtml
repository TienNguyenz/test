@page "{id:int}"
@model TechStoreWeb.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<div class="page-head mb-4">
    <h2>Delete Product</h2>
    <p>This action removes the product from HQ and attempts to remove Branch mirror.</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Product is not null)
{
    <div class="glass-card p-4">
        <p class="mb-1"><strong>ProductID:</strong> @Model.Product.ProductID</p>
        <p class="mb-1"><strong>Name:</strong> @Model.Product.ProductName</p>
        <p class="mb-1"><strong>Category:</strong> @Model.Product.Category</p>
        <p class="mb-3"><strong>Price:</strong> @Model.Product.Price.ToString("N0")</p>

        <div class="alert alert-warning">
            Deletion will be blocked if Branch invoices already reference this product.
        </div>

        <form method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">Confirm Delete</button>
            <a asp-page="/Products/Index" class="btn btn-soft">Cancel</a>
        </form>
    </div>
}
