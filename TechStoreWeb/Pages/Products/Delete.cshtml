@page "{id:int}"
@model TechStoreWeb.Pages.Products.DeleteModel
@{
    ViewData["Title"] = "Delete Product";
}

<div class="page-head mb-4">
    <h2>
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--bad)" stroke-width="2" style="margin-right:8px;vertical-align:-4px"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6m3 0V4a2 2 0 012-2h4a2 2 0 012 2v2"/></svg>
        Delete Product
    </h2>
    <p>This action removes the product from HQ and attempts to remove Branch mirror.</p>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

@if (Model.Product is not null)
{
    <div class="glass-card p-4" style="max-width:550px">
        <div class="d-flex align-items-center gap-3 mb-3">
            <div style="width:48px;height:48px;border-radius:var(--radius-sm);background:linear-gradient(135deg,var(--bad),#b91c1c);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:1.1rem;color:#fff;font-family:'Space Grotesk',sans-serif">
                @Model.Product.ProductID
            </div>
            <div>
                <h5 class="mb-0">@Model.Product.ProductName</h5>
                <span class="pill mt-1">@Model.Product.Category</span>
            </div>
        </div>

        <div class="metric-card mb-3">
            <div class="metric-label">Price</div>
            <div class="metric-value">@Model.Product.Price.ToString("N0")</div>
        </div>

        <div class="alert alert-warning">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;vertical-align:-2px"><path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
            Deletion will be blocked if Branch invoices already reference this product.
        </div>

        <form method="post" class="d-flex gap-2">
            <input type="hidden" asp-for="Id" />
            <button type="submit" class="btn btn-danger">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;vertical-align:-2px"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 01-2 2H7a2 2 0 01-2-2V6"/></svg>
                Confirm Delete
            </button>
            <a asp-page="/Products/Index" class="btn btn-soft">Cancel</a>
        </form>
    </div>
}
