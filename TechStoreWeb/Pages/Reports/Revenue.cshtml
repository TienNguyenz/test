@page
@model TechStoreWeb.Pages.Reports.RevenueModel
@{
    ViewData["Title"] = "Revenue Report";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-head flex-wrap gap-2">
    <div>
        <h2 class="mb-1">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--ok)" stroke-width="2" style="margin-right:8px;vertical-align:-4px"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
            Sales Report (Logical View)
        </h2>
        <small>Người dùng truy vấn một tập dữ liệu thống nhất — không cần biết dữ liệu nằm ở node nào.</small>
    </div>
    <a class="btn btn-soft" asp-page="/Distributed/Evidence">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;vertical-align:-2px"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/></svg>
        Technical Evidence
    </a>
</div>

<form method="get" class="row g-3 mb-4 glass-card p-4">
    <div class="col-md-3">
        <label asp-for="FromDate" class="form-label">From Date</label>
        <input asp-for="FromDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="ToDate" class="form-label">To Date</label>
        <input asp-for="ToDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-brand" type="submit">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;vertical-align:-2px"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
            Apply Filter
        </button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">Không tải được báo cáo: @Model.ErrorMessage</div>
}
else
{
    <div class="row g-3 mb-4">
        <div class="col-md-3 col-6">
            <div class="metric-card">
                <div class="metric-label">Total Revenue</div>
                <div class="metric-value" style="color:var(--ok)">@Model.GrandRevenue.ToString("N0")</div>
            </div>
        </div>
        <div class="col-md-3 col-6">
            <div class="metric-card">
                <div class="metric-label">Total Units</div>
                <div class="metric-value">@Model.TotalUnits</div>
            </div>
        </div>
    </div>

    <div class="table-responsive glass-card p-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ProductID</th>
                    <th>ProductName</th>
                    <th>Category</th>
                    <th class="text-end">UnitPrice</th>
                    <th class="text-end">SoLuongBan</th>
                    <th class="text-end">DoanhThu</th>
                    <th>LatestSaleDate</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td style="font-family:'Space Grotesk',sans-serif;font-weight:500;color:var(--on-surface-dim)">#@row.ProductID</td>
                    <td>@row.ProductName</td>
                    <td><span class="pill">@row.Category</span></td>
                    <td class="text-end" style="font-family:'Space Grotesk',sans-serif">@row.GiaTaiHQ.ToString("N0")</td>
                    <td class="text-end" style="font-family:'Space Grotesk',sans-serif;font-weight:600">@row.SoLuongBan</td>
                    <td class="text-end" style="font-family:'Space Grotesk',sans-serif;font-weight:700;color:var(--ok)">@row.DoanhThu.ToString("N0")</td>
                    <td>@(row.LanBanGanNhat?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
