@page
@model TechStoreWeb.Pages.Reports.RevenueModel
@{
    ViewData["Title"] = "Revenue Report";
}

<div class="d-flex justify-content-between align-items-center mb-3 page-head">
    <div>
        <h2 class="mb-0">Revenue Report</h2>
        <small class="text-muted">Integrated summary from SQL Server HQ + MySQL Branch with type normalization.</small>
    </div>
    <a class="btn btn-soft" asp-page="/Distributed/Evidence">View JOIN Evidence</a>
</div>

<form method="get" class="row g-3 mb-3 glass-card p-3">
    <div class="col-md-3">
        <label asp-for="FromDate" class="form-label">From Date</label>
        <input asp-for="FromDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3">
        <label asp-for="ToDate" class="form-label">To Date</label>
        <input asp-for="ToDate" class="form-control" type="date" />
    </div>
    <div class="col-md-3 d-flex align-items-end">
        <button class="btn btn-brand" type="submit">Apply Filter</button>
    </div>
</form>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">Khong tai duoc bao cao: @Model.ErrorMessage</div>
}
else
{
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="metric-card">
                <div class="card-body">
                    <div class="metric-label">Total Revenue</div>
                    <div class="metric-value">@Model.GrandRevenue.ToString("N0")</div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="metric-card">
                <div class="card-body">
                    <div class="metric-label">Total Units</div>
                    <div class="metric-value">@Model.TotalUnits</div>
                </div>
            </div>
        </div>
    </div>

    <div class="table-responsive glass-card p-2">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ProductID</th>
                    <th>ProductName</th>
                    <th>Category</th>
                    <th class="text-end">GiaTaiHQ</th>
                    <th class="text-end">SoLuongBan</th>
                    <th class="text-end">DoanhThu</th>
                    <th>LanBanGanNhat</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var row in Model.Rows)
            {
                <tr>
                    <td>@row.ProductID</td>
                    <td>@row.ProductName</td>
                    <td>@row.Category</td>
                    <td class="text-end">@row.GiaTaiHQ.ToString("N0")</td>
                    <td class="text-end">@row.SoLuongBan</td>
                    <td class="text-end">@row.DoanhThu.ToString("N0")</td>
                    <td>@(row.LanBanGanNhat?.ToString("yyyy-MM-dd HH:mm:ss") ?? "-")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
