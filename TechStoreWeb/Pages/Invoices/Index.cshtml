@page
@model TechStoreWeb.Pages.Invoices.IndexModel
@{
    ViewData["Title"] = "Invoices";
}

<div class="d-flex justify-content-between align-items-center mb-4 page-head flex-wrap gap-2">
    <div>
        <h2 class="mb-1">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--warn)" stroke-width="2" style="margin-right:8px;vertical-align:-4px"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
            Invoices (Logical View)
        </h2>
        <small>Dữ liệu hóa đơn được truy cập qua lớp logic thống nhất của hệ thống phân tán.</small>
    </div>
    <a class="btn btn-soft" asp-page="/Distributed/Evidence">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="margin-right:6px;vertical-align:-2px"><circle cx="12" cy="12" r="10"/><path d="M2 12h20"/></svg>
        See Distributed Proof
    </a>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">Could not load data: @Model.ErrorMessage</div>
}
else if (Model.Invoices.Count == 0)
{
    <div class="alert alert-warning">No invoices found.</div>
}
else
{
    <div class="row mb-4">
        <div class="col-md-4 col-6">
            <div class="metric-card">
                <div class="metric-label">Total Invoice Revenue</div>
                <div class="metric-value" style="color:var(--ok)">@Model.TotalRevenue.ToString("N0")</div>
            </div>
        </div>
    </div>

    <div class="table-responsive glass-card p-3">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>InvoiceID</th>
                    <th>ProductID</th>
                    <th class="text-end">Quantity</th>
                    <th>SaleDate</th>
                    <th class="text-end">Total</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var item in Model.Invoices)
            {
                <tr>
                    <td style="font-family:'Space Grotesk',sans-serif;font-weight:500;color:var(--on-surface-dim)">#@item.InvoiceID</td>
                    <td>@item.ProductID</td>
                    <td class="text-end" style="font-family:'Space Grotesk',sans-serif;font-weight:600">@item.Quantity</td>
                    <td>@item.SaleDate.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td class="text-end" style="font-family:'Space Grotesk',sans-serif;font-weight:700">@item.Total.ToString("N0")</td>
                </tr>
            }
            </tbody>
        </table>
    </div>
}
